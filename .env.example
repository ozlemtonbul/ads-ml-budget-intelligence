# ============================================================
# GOOGLE ADS
# ============================================================

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# ============================================================
# GOOGLE ANALYTICS 4 (GA4)
# ============================================================

GA4_PROPERTY_ID=

# Path to the Google Analytics 4 service account JSON file.
GA4_SERVICE_ACCOUNT_FILE=./credentials/ga4_service_account.json

# ============================================================
# DATE RANGE
# ============================================================

# Supported values:
# custom
# last_30_days
# last_60_days
# last_90_days
# last_180_days
# last_365_days

DATE_MODE=last_60_days

# Required only when DATE_MODE=custom

DATE_FROM=
DATE_TO=

# ============================================================
# BUSINESS TARGET
# ============================================================

TARGET_ROAS=3.0

# ============================================================
# LARGE LANGUAGE MODEL (LLM)
# ============================================================

# Supported providers:
# anthropic
# openai
# gemini

LLM_ENABLED=true
LLM_PROVIDER=anthropic

# Enter the model that belongs to the selected provider.
#
# Anthropic:
# claude-sonnet-4-6
#
# OpenAI:
# gpt-5.1
#
# Gemini:
# gemini-2.5-pro

LLM_MODEL=claude-sonnet-4-6

LLM_LANGUAGE=en
LLM_MAX_CAMPAIGNS=20
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2

# Fill in only the API key for the selected provider.
# Leave the remaining provider keys empty.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ============================================================
# OUTPUT
# ============================================================

OUTPUT_DIR=./outputs

# ============================================================
# POSTGRESQL
# ============================================================

POSTGRES_ENABLED=false

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ads_budget
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Supported values:
# replace
# append
# fail

POSTGRES_IF_EXISTS=replace